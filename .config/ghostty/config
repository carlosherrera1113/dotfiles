font-size = 15
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# One Dark Pro color scheme

# One Dark colors
background = "#282c34"
foreground = "#abb2bf"

# Normal colors (0-7)
palette = 0=#282c34
palette = 1=#e06c75
palette = 2=#98c379
palette = 3=#e5c07b
palette = 4=#61afef
palette = 5=#c678dd
palette = 6=#56b6c2
palette = 7=#abb2bf

# Bright colors (8-15)
palette = 8=#5c6370
palette = 9=#e06c75
palette = 10=#98c379
palette = 11=#e5c07b
palette = 12=#61afef
palette = 13=#c678dd
palette = 14=#56b6c2
palette = 15=#ffffff

# Cursor - Matching opencode style (block, blinking, greyish)
cursor-style = block
cursor-style-blink = true
shell-integration = zsh
shell-integration-features = no-cursor
cursor-color = "#abb2bf"
cursor-text = "#282c34"

# Selection
selection-background = "#3e4451"
selection-foreground = "#abb2bf"

# Compact settings
window-padding-x = 4
window-padding-y = 2

# Send Shift+Enter as ESC+Enter (for OpenCode, Claude Code, etc.)
keybind = shift+enter=text:\x1b\r
